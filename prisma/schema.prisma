generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── BETTER AUTH ─────────────────────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  members OrganizationMember[]
  ProgramPanelist ProgramPanelist[]
  ProgramMember ProgramMember[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ─── ORGANIZATION ──────────────────────────────────────────────────────────────

model Organization {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members    OrganizationMember[]
  invites    OrganizationInvite[]
  programs   Program[]
  agencies   Agency[]
  candidates Candidate[]
}

model OrganizationMember {
  id             Int          @id @default(autoincrement())
  userId         String
  organizationId Int
  role           OrgRole      @default(MEMBER)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model OrganizationInvite {
  id             Int      @id @default(autoincrement())
  email          String
  organizationId Int
  role           OrgRole  @default(MEMBER)
  invitedBy      String
  createdAt      DateTime @default(now())
  acceptedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([email, organizationId])
}

enum OrgRole {
  ADMIN
  MEMBER
}

// ─── PROGRAMS & ROUNDS ─────────────────────────────────────────────────────────

model Program {
  id             Int       @id @default(autoincrement())
  name           String
  description    String?
  organizationId Int
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization      @relation(fields: [organizationId], references: [id])
  rounds       Round[]
  panelists    ProgramPanelist[]
  candidates   Candidate[]
  agencies     Agency[]
  members      ProgramMember[]
}

model ProgramMember {
  id             Int          @id @default(autoincrement())
  programId      Int
  userId         String
  role           ProgramRole  @default(HR)
  
  program        Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([programId, userId])
}

enum ProgramRole {
  LEAD
  HR
}

model Round {
  id              Int       @id @default(autoincrement())
  name            String
  description     String?
  roundNumber     Int
  durationMinutes Int       @default(60)
  roundType       RoundType @default(HUMAN_INTERVIEW)
  focusAreas      Json?     @default("[]")
  programId       Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  program          Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  panelists        ProgramPanelist[]
  bookings         Booking[]
  activeCandidates Candidate[]       @relation("ActiveRound")
}

enum RoundType {
  ATS_SCREENING
  HUMAN_INTERVIEW
  ASSIGNMENT
}

// ─── PANELIST ENGINE (Supply) ──────────────────────────────────────────────────

model ProgramPanelist {
  id              Int       @id @default(autoincrement())
  programId       Int
  roundId         Int
  userId          String?
  externalEmail   String?
  externalName    String?
  magicLinkToken  String    @unique
  magicLinkTokenExp DateTime?
  magicLinkUsedAt DateTime?
  availableSlots  Json      @default("[]")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  program  Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  round    Round     @relation(fields: [roundId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  bookings Booking[]
}

// ─── AGENCIES ──────────────────────────────────────────────────────────────────

model Agency {
  id             Int      @id @default(autoincrement())
  name           String
  contactPerson  String?
  email          String
  magicLinkToken String   @unique
  organizationId Int
  programId      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program      Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  candidates   Candidate[]
}

// ─── CANDIDATE PIPELINE (Demand) ───────────────────────────────────────────────

model Candidate {
  id              Int             @id @default(autoincrement())
  programId       Int
  organizationId  Int
  name            String
  email           String
  phone           String?
  linkedIn        String?
  currentRole     String?
  currentCompany  String?
  yearsExperience Int?
  notes           String?
  resumeUrl       String?
  source          CandidateSource @default(DIRECT)
  agencyId        Int?
  atsScore        Float?
  atsReason       String?
  status          CandidateStatus @default(DRAFT)
  activeRoundId   Int?
  bookingToken    String?         @unique
  bookingTokenExp DateTime?
  bookingRoundId  Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  program      Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activeRound  Round?       @relation("ActiveRound", fields: [activeRoundId], references: [id])
  agency       Agency?      @relation(fields: [agencyId], references: [id])
  bookings     Booking[]

  @@unique([programId, email])
}

enum CandidateSource {
  DIRECT
  AGENCY
}

enum CandidateStatus {
  SCREENING
  DRAFT
  SHORTLISTED
  ACTIVE
  BOOKED
  COMPLETED
  REJECTED
}

// ─── BOOKINGS ──────────────────────────────────────────────────────────────────

model Booking {
  id                Int           @id @default(autoincrement())
  candidateId       Int
  programPanelistId Int
  roundId           Int
  slotStart         DateTime
  slotEnd           DateTime
  status            BookingStatus @default(SCHEDULED)
  fulfillmentStatus FulfillmentStatus @default(PENDING)
  meetingLink       String?
  googleEventId     String?
  aiRubric          Json?
  score             Float?
  verdict           Verdict?
  feedback          String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  candidate       Candidate       @relation(fields: [candidateId], references: [id])
  programPanelist ProgramPanelist @relation(fields: [programPanelistId], references: [id])
  round           Round           @relation(fields: [roundId], references: [id])
}

enum FulfillmentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BookingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum Verdict {
  PASS
  FAIL
  HOLD
}
